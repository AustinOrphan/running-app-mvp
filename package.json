{
  "name": "running-app-mvp",
  "version": "1.0.0",
  "description": "Running tracker web app MVP",
  "main": "server.js",
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "vite --host",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:frontend": "vite",
    "dev:backend": "tsx watch src/server/index.ts",
    "dev:debug": "tsx --inspect-brk src/server/index.ts",
    "build": "vite build",
    "build:watch": "vite build --watch",
    "build:analyze": "vite build --mode analyze",
    "start": "node dist/server/index.js",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:watch": "vitest --watch",
    "test:ui": "vitest --ui",
    "test:debug": "vitest --inspect-brk",
    "test:unit": "vitest run src/",
    "test:integration": "jest tests/integration",
    "test:server": "vitest run src/server",
    "test:client": "vitest run src/client",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:all": "npm run test:coverage && npm run test:e2e",
    "quality": "npm run lint:fix && npm run format && npm run typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:server": "eslint src/server --ext .ts",
    "lint:client": "eslint src/client --ext .ts,.tsx",
    "lint:shared": "eslint src/shared --ext .ts",
    "lint:staged": "lint-staged",
    "lint:watch": "eslint . --ext .ts,.tsx --watch",
    "lint:quiet": "eslint . --quiet",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist node_modules/.vite node_modules/.cache .eslintcache coverage playwright-report test-results",
    "clean:build": "rm -rf dist",
    "clean:cache": "rm -rf node_modules/.vite node_modules/.cache .eslintcache",
    "clean:test": "rm -rf coverage playwright-report test-results",
    "clean:db": "rm -rf prisma/dev.db*",
    "fresh": "rm -rf node_modules package-lock.json && npm install && npm run setup",
    "reset": "npm run clean && npm run db:reset && npm run setup",
    "perf": "lhci autorun",
    "perf:local": "lighthouse http://localhost:4173 --view",
    "perf:report": "lhci autorun --collect.url=http://localhost:4173",
    "debug": "tsx --inspect-brk src/server/index.ts",
    "debug:test": "npm run test:debug",
    "debug:build": "vite build --mode development --sourcemap",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma migrate reset --force",
    "setup": "npm install && npm run db:migrate && npm run db:generate",
    "ci": "npm run quality && npm run test:all",
    "prepare": "husky"
  },
  "dependencies": {
    "@mdi/svg": "^7.4.47",
    "@prisma/client": "^6.13.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.0",
    "express": "^5.1.0",
    "express-rate-limit": "^8.0.1",
    "helmet": "^8.1.0",
    "js-yaml": "^4.1.0",
    "jsonwebtoken": "^9.0.2",
    "react": "19.1.1",
    "react-dom": "19.1.1",
    "react-router-dom": "^7.6.3",
    "recharts": "^3.1.0",
    "uuid": "^11.1.0",
    "winston": "^3.17.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@axe-core/react": "^4.10.2",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@faker-js/faker": "^10.0.0",
    "@playwright/test": "^1.54.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.3",
    "@types/express-rate-limit": "^5.1.3",
    "@types/jest": "^30.0.0",
    "@types/jest-axe": "^3.5.9",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^24.0.13",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^10.0.0",
    "@types/winston": "^2.4.4",
    "@typescript-eslint/eslint-plugin": "^8.36.0",
    "@typescript-eslint/parser": "^8.36.0",
    "@vitejs/plugin-react": "^5.0.2",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "autoprefixer": "^10.4.16",
    "axe-core": "^4.10.3",
    "chromium-bidi": "^8.0.0",
    "complexity-report": "^2.0.0-alpha",
    "concurrently": "^9.2.0",
    "cross-env": "^10.0.0",
    "eslint": "^9.31.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-security": "^3.0.1",
    "eslint-plugin-testing-library": "^7.6.0",
    "eslint-plugin-unicorn": "^60.0.0",
    "husky": "^9.1.7",
    "jest": "^30.0.4",
    "jest-axe": "^10.0.0",
    "jest-junit": "^16.0.0",
    "jscpd": "^4.0.5",
    "jsdom": "^26.1.0",
    "lint-staged": "^16.1.2",
    "pixelmatch": "^7.1.0",
    "playwright": "^1.54.0",
    "pngjs": "^7.0.0",
    "postcss": "^8.4.32",
    "prettier": "^3.6.2",
    "prisma": "^6.13.0",
    "rollup": "^4.45.0",
    "supertest": "^7.1.3",
    "tailwindcss": "^4.1.11",
    "ts-jest": "^29.4.0",
    "tsx": "^4.6.2",
    "typescript": "^5.3.3",
    "vite": "^7.0.4",
    "vitest": "^3.2.4"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.45.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write",
      "vitest related --run"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "volta": {
    "node": "24.7.0"
  }
}
