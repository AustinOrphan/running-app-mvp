echo "🔍 Running pre-push checks..."

# Check code coverage
echo "📊 Checking code coverage..."
npm run test:coverage

if [ $? -ne 0 ]; then
  echo "❌ Code coverage check failed!"
  echo ""
  echo "Please ensure tests pass and coverage is adequate before pushing:"
  echo "  • Run 'npm run test:coverage' to check coverage"
  echo "  • Add tests for uncovered code"
  echo "  • Run 'npm run test:watch' while adding tests"
  echo ""
  echo "Push blocked due to test/coverage issues."
  exit 1
fi

echo "✅ Code coverage check passed!"

# Run lint check
echo "🧹 Running lint check..."
npm run lint

if [ $? -ne 0 ]; then
  echo "❌ Lint check failed!"
  echo "Run 'npm run lint:fix' to fix issues"
  exit 1
fi

echo "✅ All pre-push checks passed!"